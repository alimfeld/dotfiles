#!/usr/bin/env bash

# Skills root directory (stowed from dot-agents/skills/)
SKILLS_DIR="$HOME/.agents/skills"
SOURCES_FILE="$SKILLS_DIR/sources.json"

usage() {
    echo "Usage:"
    echo "  agent-skills fetch <github-url> [category]   Fetch a new skill from GitHub"
    echo "  agent-skills update [name]                   Update all or a named skill"
    exit 1
}

# Parse a GitHub tree URL into GH_CLONE_URL, GH_BRANCH, GH_PATH
# Input: https://github.com/owner/repo/tree/branch/path/to/dir
parse_github_url() {
    local url="$1"
    local rest="${url#https://github.com/}"
    local owner repo branch

    owner=$(echo "$rest" | cut -d'/' -f1)
    repo=$(echo "$rest" | cut -d'/' -f2)
    branch=$(echo "$rest" | cut -d'/' -f4)
    GH_PATH=$(echo "$rest" | cut -d'/' -f5-)
    GH_BRANCH="$branch"
    GH_CLONE_URL="https://github.com/$owner/$repo"
}

# Sync a skill from its src URL to a relative destination path (e.g. general/grill-me)
sync_skill() {
    local src="$1"
    local dest_path="$2"
    local dest="$SKILLS_DIR/$dest_path"

    parse_github_url "$src"

    echo "Syncing $dest_path..."

    local tmp_dir
    tmp_dir=$(mktemp -d)

    # Sparse clone — only fetch the relevant subdirectory
    git clone --no-checkout --depth=1 --filter=blob:none "$GH_CLONE_URL" "$tmp_dir" --quiet 2>&1
    git -C "$tmp_dir" sparse-checkout set "$GH_PATH"
    git -C "$tmp_dir" checkout --quiet

    # Clean sync: wipe destination and replace with upstream content
    rm -rf "$dest"
    mkdir -p "$dest"
    cp -r "$tmp_dir/$GH_PATH/." "$dest/"

    rm -rf "$tmp_dir"

    echo "  Done → $dest"
}

cmd_fetch() {
    local url="$1"
    local category="${2:-general}"

    if [[ -z "$url" ]]; then
        usage
    fi

    local name dest_path
    name=$(basename "$url")
    dest_path="$category/$name"

    # Create sources.json if missing
    if [[ ! -f "$SOURCES_FILE" ]]; then
        echo "[]" > "$SOURCES_FILE"
    fi

    # Update existing entry or append new one
    local existing
    existing=$(jq -r --arg path "$dest_path" '.[] | select(.path == $path) | .path' "$SOURCES_FILE")

    if [[ -n "$existing" ]]; then
        echo "Updating existing entry for '$dest_path' in sources.json..."
        jq --arg path "$dest_path" --arg src "$url" \
            'map(if .path == $path then .src = $src else . end)' \
            "$SOURCES_FILE" > "$SOURCES_FILE.tmp" && cp "$SOURCES_FILE.tmp" "$SOURCES_FILE" && rm "$SOURCES_FILE.tmp"
    else
        echo "Adding '$dest_path' to sources.json..."
        jq --arg path "$dest_path" --arg src "$url" \
            '. += [{"path": $path, "src": $src}]' \
            "$SOURCES_FILE" > "$SOURCES_FILE.tmp" && cp "$SOURCES_FILE.tmp" "$SOURCES_FILE" && rm "$SOURCES_FILE.tmp"
    fi

    sync_skill "$url" "$dest_path"
}

cmd_update() {
    local name="$1"

    if [[ ! -f "$SOURCES_FILE" ]]; then
        echo "No sources.json found at $SOURCES_FILE"
        exit 1
    fi

    if [[ -n "$name" ]]; then
        # Match by full path or by skill name (last segment)
        local entry
        entry=$(jq -c --arg name "$name" \
            '.[] | select(.path == $name or (.path | split("/")[-1]) == $name)' \
            "$SOURCES_FILE")

        if [[ -z "$entry" ]]; then
            echo "Skill '$name' not found in sources.json"
            exit 1
        fi

        local src path
        src=$(echo "$entry" | jq -r '.src')
        path=$(echo "$entry" | jq -r '.path')
        sync_skill "$src" "$path"
    else
        # Update all skills
        while IFS= read -r entry; do
            local src path
            src=$(echo "$entry" | jq -r '.src')
            path=$(echo "$entry" | jq -r '.path')
            sync_skill "$src" "$path"
        done < <(jq -c '.[]' "$SOURCES_FILE")
    fi
}

case "$1" in
    fetch)
        shift
        cmd_fetch "$@"
        ;;
    update)
        shift
        cmd_update "$@"
        ;;
    *)
        usage
        ;;
esac
